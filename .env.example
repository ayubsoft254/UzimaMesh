# Django Settings
DJANGO_SECRET_KEY=yoursecretkeyhere
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# For local dev, db.sqlite3 is used if DATABASE_URL is not set.
# DATABASE_URL=postgres://user:password@host:port/dbname

# Azure Authentication (Microsoft Entra ID)
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=common

# Azure Managed Identity (if using local service principal for testing)
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_TENANT_ID=...

# Azure AI Foundry Agent settings
# Option A (recommended): full project connection string from Azure AI Foundry
AZURE_AI_PROJECT_CONNECTION_STRING=
# Option B: endpoint + project identity parts
AZURE_AI_ENDPOINT=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_AI_PROJECT_NAME=
# Agent/assistant id used by the app
AZURE_AI_AGENT_ID=
# Optional per-role override used by the intake flow
AZURE_AI_INTAKE_AGENT_ID=
